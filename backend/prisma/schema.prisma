generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model staff {
  id          Int @id @unique @default(autoincrement())
  name        String
  email       String
  department  String
  createdAt   DateTime @default(now())
}

model user {
  id        Int      @id @unique @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}